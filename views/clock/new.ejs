<% const content = `
  <main class="clock-tool">
    <h1>Clock</h1>
    <p class="tagline">Configure a clock display and generate a plain URL with parameters instead of a stored share ID.</p>

    <form id="clock-config-form" class="clock-config-form">
      <div class="password-options-grid">
        <fieldset class="password-fieldset">
          <legend>Main clock</legend>

          <label for="clock-type">Clock type</label>
          <select id="clock-type" name="clockType">
            <option value="digital" selected>Digital</option>
            <option value="analog">Analogue (Swiss railway)</option>
            <option value="none">None</option>
          </select>

          <label class="checkbox-option"><input type="checkbox" id="clock-show-seconds" checked> Show seconds</label>
          <p class="hint">Analogue mode adapts the original <a href="https://github.com/manuelmeister/Swiss-Railway-Clock" target="_blank" rel="noopener noreferrer">Swiss-Railway-Clock source code</a> by Manuel Meister.</p>
        </fieldset>

        <fieldset class="password-fieldset">
          <legend>Countdown</legend>

          <label class="checkbox-option"><input type="checkbox" id="countdown-enabled"> Show countdown</label>

          <div class="clock-duration-grid">
            <div class="password-field">
              <label for="countdown-hours">Hours</label>
              <input type="number" id="countdown-hours" min="0" max="999" value="0">
            </div>

            <div class="password-field">
              <label for="countdown-minutes">Minutes</label>
              <input type="number" id="countdown-minutes" min="0" max="59" value="15">
            </div>

            <div class="password-field">
              <label for="countdown-seconds-input">Seconds</label>
              <input type="number" id="countdown-seconds-input" min="0" max="59" value="0">
            </div>
          </div>

          <label class="checkbox-option"><input type="checkbox" id="countdown-show-seconds"> Show seconds</label>
          <label class="checkbox-option"><input type="checkbox" id="countdown-color" checked> Enable warning colors</label>
          <p class="hint">Warning colors switch to yellow, orange, and red during the last 1/3, 1/6, and 1/12 of the countdown.</p>
        </fieldset>
      </div>

      <div class="clock-config-actions">
        <button type="button" id="clock-generate-link-btn">Generate Link</button>
      </div>
    </form>

    <section class="password-output" id="clock-link-section">
      <label for="clock-link-output">Clock link</label>
      <input type="text" id="clock-link-output" readonly>

      <div class="password-actions">
        <button type="button" id="clock-copy-link-btn" class="copy-btn">Copy</button>
        <a id="clock-open-link" class="download-btn clock-open-link" href="#" hidden>Open Clock</a>
      </div>

      <p id="clock-config-meta" class="hint">Generate a link to freeze the countdown start time.</p>
      <p id="clock-config-error" class="error" hidden></p>
    </section>

    <p><a href="/">Back to home</a></p>
  </main>

  <script src="/public/clock-config.js"></script>
` %>
<%- include('../layout', { content, title }) %>
